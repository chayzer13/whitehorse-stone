# Скопируйте этот файл в .env и заполните значения

# Пароль администратора для входа в /admin  (ОБЯЗАТЕЛЬНО изменить!)
ADMIN_PASSWORD=ваш_надёжный_пароль

# Порт сервера (по умолчанию 3000)
PORT=3000

# Настройки MySQL (Reg.ru или Railway MySQL)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# IndexNow для Яндекса
INDEXNOW_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6
SITE_URL=https://whitehorsestone.ru
